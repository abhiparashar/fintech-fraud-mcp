# Copy this to .env and fill in real values
# .env is gitignored — never commit it

# ── Main database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fintechdb
DB_USER=postgres
DB_PASSWORD=changeme

# ── Read-only pool (query_transactions) ──────────────────────────
# Run migrations/002_readonly_user.sql to create this user
DB_READONLY_USER=fraud_reader
DB_READONLY_PASSWORD=changeme

# ── MCP auth ─────────────────────────────────────────────────────
# Single key:   MCP_API_KEY=mysecret
# Multi-caller: MCP_API_KEY=analyst1:key1,admin:key2
# Leave blank to disable (fine for local dev)
MCP_API_KEY=

# ── Scheduled materialized view refresh ──────────────────────────
# How often (seconds) to auto-refresh the fraud_user_flags view.
# Default 300 (5 minutes).
MV_REFRESH_INTERVAL_SECONDS=300

# ── Rate limiting (per caller, sliding window) ────────────────────
# Only applies when MCP_API_KEY is set.
# Default: 60 requests per 60 seconds per caller identity.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
