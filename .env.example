# Copy this to .env and fill in real values
# .env is gitignored — never commit it

# ── Main database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fintechdb
DB_USER=postgres
DB_PASSWORD=changeme

# ── Read-only pool (query_transactions) ──────────────────────────
# Run migrations/002_readonly_user.sql to create this user
DB_READONLY_USER=fraud_reader
DB_READONLY_PASSWORD=changeme

# ── MCP auth ─────────────────────────────────────────────────────
# When set, every request to /sse must include X-API-Key: <value>
# Leave blank to disable (fine for local dev)
MCP_API_KEY=
